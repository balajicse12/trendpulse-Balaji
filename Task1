import requests
import json
import time
import os
from datetime import datetime

def main():
    # 1. Define Categories and Keywords
    categories = {
        "technology": ["ai", "software", "tech", "code", "computer", "data", "cloud", "api", "gpu", "llm"],
        "worldnews": ["war", "government", "country", "president", "election", "climate", "attack", "global"],
        "sports": ["nfl", "nba", "fifa", "sport", "game", "team", "player", "league", "championship"],
        "science": ["research", "study", "space", "physics", "biology", "discovery", "nasa", "genome"],
        "entertainment": ["movie", "film", "music", "netflix", "game", "book", "show", "award", "streaming"]
    }

    headers = {"User-Agent": "TrendPulse/1.0"}
    all_collected_stories = []

    print("Fetching top 500 story IDs from HackerNews...")

    # 2. Fetch the Top 500 Story IDs
    try:
        top_stories_url = "https://hacker-news.firebaseio.com/v0/topstories.json"
        response = requests.get(top_stories_url, headers=headers)
        response.raise_for_status() # Check for HTTP errors
        top_500_ids = response.json()[:500]
    except Exception as e:
        print(f"Critical Error: Failed to fetch top stories. {e}")
        return

    # 3. The Category Loop
    for category_name, keywords in categories.items():
        print(f"Hunting for {category_name} stories...")
        stories_found_for_this_category = 0
        
        # 4. The Story Fetch Loop
        for story_id in top_500_ids:
            # Stop if we hit the 25 story cap for this specific category
            if stories_found_for_this_category >= 25:
                break
                
            story_url = f"https://hacker-news.firebaseio.com/v0/item/{story_id}.json"
            
            try:
                story_response = requests.get(story_url, headers=headers)
                if story_response.status_code != 200:
                    continue
                    
                story = story_response.json()
                
                # Skip empty stories or stories without a title
                if not story or 'title' not in story:
                    continue
                    
                # Convert title to lowercase for case-insensitive matching
                title_lower = story['title'].lower()
                
                # 5. Check if ANY keyword exists in the lowercased title
                # Using a generator expression with 'any()' for clean, readable logic
                is_match = any(keyword in title_lower for keyword in keywords)
                
                # 6. Extract Fields if it's a match
                if is_match:
                    extracted_data = {
                        "post_id": story.get("id"),
                        "title": story.get("title"),
                        "category": category_name,
                        "score": story.get("score", 0),
                        # Use .get() with a default of 0 to prevent KeyErrors on posts with no comments
                        "num_comments": story.get("descendants", 0), 
                        "author": story.get("by", "unknown"),
                        "collected_at": datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                    }
                    
                    all_collected_stories.append(extracted_data)
                    stories_found_for_this_category += 1
                    
            except Exception as e:
                # Print a message and move on; don't crash the script
                print(f"Failed to fetch story {story_id}. Error: {e}")
                continue 
                
        print(f"Finished {category_name}. Found {stories_found_for_this_category} stories.")
        
        # 7. The Mandatory Sleep (Wait 2 seconds between categories, not individual stories)
        time.sleep(2)

    # 8. Create Data Folder and Save File
    total_stories = len(all_collected_stories)
    print(f"\nData collection complete.")

    # Create the 'data' directory if it doesn't already exist
    os.makedirs("data", exist_ok=True)
    
    # Generate the dynamic filename with today's date
    date_string = datetime.now().strftime("%Y%m%d")
    filename = f"data/trends_{date_string}.json"
    
    # Save the JSON data
    with open(filename, "w", encoding="utf-8") as f:
        json.dump(all_collected_stories, f, indent=4)

    print(f"Collected {total_stories} stories. Saved to {filename}")

if __name__ == "__main__":
    main()